# ============================
# BookSocial 前端环境变量模板
# 复制此文件为 .env 并填写实际值
# 所有前端变量必须以 VITE_ 开头
# ============================

# 后端 API 地址
# 开发环境: http://localhost:3001/api/v1
# Docker 部署: /api/v1（通过 Nginx 反向代理）
# 独立部署: https://api.yourdomain.com/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# Cloudinary 图片服务
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
